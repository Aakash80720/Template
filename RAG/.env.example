# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
MODEL_NAME=gpt-4o
FALLBACK_MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
TEMPERATURE=0.0
MAX_TOKENS=4096

# ── LangSmith (optional) ──────────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=knowledge-graph

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=kg_entities

# ── Knowledge Graph ───────────────────────────────────────────────────────────
KG_PERSIST_PATH=./data/knowledge_graph.json

# ── Neo4j (optional — leave blank to use NetworkX) ────────────────────────────
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# ── MCP Bridge ────────────────────────────────────────────────────────────────
MCP_SERVER_URL=
MCP_AUTH_TOKEN=

# ── GitHub Connector ─────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── spaCy ─────────────────────────────────────────────────────────────────────
SPACY_MODEL=en_core_web_trf

# ── Pipeline ──────────────────────────────────────────────────────────────────
HITL_ENABLED=true
MAX_ITERATIONS=20
